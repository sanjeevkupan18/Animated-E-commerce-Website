<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400" width="600" height="400">
  <defs>
    <radialGradient id="bg2" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#0d0d1a"/>
      <stop offset="100%" stop-color="#080808"/>
    </radialGradient>
  </defs>
  <rect width="600" height="400" fill="url(#bg2)"/>
  <ellipse cx="300" cy="340" rx="220" ry="22" fill="#fff" opacity="0.05"/>
  <!-- Main body -->
  <path d="M80 280 Q120 170 210 150 L370 140 Q470 138 510 175 Q530 200 510 235 Q420 265 80 255 Z" fill="#e8e8e8" stroke="#fff" stroke-width="1"/>
  <path d="M90 278 Q125 178 215 158 L365 148 Q460 146 498 180 Q515 202 498 232 Q415 258 90 250 Z" fill="#f0f0f0"/>
  <!-- Knit texture lines -->
  <path d="M130 250 Q200 200 300 195 Q400 190 490 225" stroke="#ddd" stroke-width="1" fill="none" opacity="0.5"/>
  <path d="M120 240 Q200 190 300 185 Q400 180 495 218" stroke="#ddd" stroke-width="1" fill="none" opacity="0.3"/>
  <!-- Tongue + laces -->
  <path d="M200 150 L215 110 Q220 90 235 92 L290 95 Q300 97 298 112 L292 148" fill="#C8FF00"/>
  <path d="M290 148 L295 100 Q298 88 310 90 L345 93 Q356 96 353 110 L348 147" fill="#C8FF00" opacity="0.7"/>
  <!-- Laces white -->
  <line x1="210" y1="146" x2="347" y2="142" stroke="#fff" stroke-width="2" opacity="0.8"/>
  <line x1="213" y1="136" x2="343" y2="132" stroke="#fff" stroke-width="1.5" opacity="0.6"/>
  <line x1="217" y1="126" x2="338" y2="122" stroke="#fff" stroke-width="1.5" opacity="0.4"/>
  <!-- Sole accent -->
  <path d="M80 255 Q420 265 510 235 L515 258 Q420 288 80 278 Z" fill="#C8FF00"/>
  <path d="M80 270 Q420 280 515 252 L515 258 Q420 288 80 278 Z" fill="#a0cc00"/>
  <!-- Brand -->
  <text x="130" y="232" font-family="Arial Black" font-size="14" fill="#888" letter-spacing="3">SOLESTEP</text>
</svg>
